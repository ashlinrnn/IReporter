{
    "info": {
    "name": "IReporter API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
    {
        "name": "Auth",
        "item": [
        { "name": "Signup", "request": { "method": "POST", "url": "{{base_url}}/auth/signup", "body": { "mode": "raw", "raw": "{\"username\":\"test\",\"email\":\"test@example.com\",\"password\":\"pass123\"}" } } },
        { "name": "Login", "request": { "method": "POST", "url": "{{base_url}}/auth/login", "body": { "mode": "raw", "raw": "{\"email\":\"test@example.com\",\"password\":\"pass123\"}" } } },
        { "name": "Get Current User", "request": { "method": "GET", "url": "{{base_url}}/auth/me", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] } }
        ]
    },
    {
        "name": "Records",
        "item": [
        { "name": "Create Record", "request": { "method": "POST", "url": "{{base_url}}/records/create", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\"title\":\"Bad road\",\"description\":\"Potholes on Main St\",\"type\":\"intervention\",\"latitude\":-1.286389,\"longitude\":36.817223}" } } },
        { "name": "List Records", "request": { "method": "GET", "url": "{{base_url}}/records?page=1&per_page=10", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] } },
        { "name": "Update Own Record", "request": { "method": "PATCH", "url": "{{base_url}}/records/me/1", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\"title\":\"Updated title\"}" } } },
        { "name": "Delete Own Record", "request": { "method": "DELETE", "url": "{{base_url}}/records/me/1", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] } }
        ]
    },
    {
        "name": "Admin",
        "item": [
        { "name": "Change Status", "request": { "method": "PATCH", "url": "{{base_url}}/admin/records/1/status", "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }], "body": { "mode": "raw", "raw": "{\"status\":\"under investigation\"}" } } }
        ]
    }
    ],
"variable": [{ "key": "base_url", "value": "http://localhost:5020/api/v1" }]
}